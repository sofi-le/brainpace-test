# Copy to .env and adjust. Expo exposes EXPO_PUBLIC_* vars to the app at build time.

# Where the FastAPI backend is reachable from the device running the app.
#   - Web preview / iOS simulator: http://localhost:8000
#   - Physical phone (Expo Go): use your computer's LAN IP, e.g. http://192.168.1.42:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Optional: pin a specific participant. Leave blank to use the first bound member
# returned by GET /members.
EXPO_PUBLIC_PARTICIPANT_ID=
